# --- LLM provider (DeepSeek, OpenAI-compatible) ---
DEEPSEEK_API_KEY=
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# --- On-chain data source (Moralis; free tier covers BSC) ---
# Sign up at https://admin.moralis.com and paste the Web3 Data API key here
MORALIS_API_KEY=

# --- Datastore (MongoDB for feature cache + verdict history) ---
MONGODB_URI=
MONGODB_DB=mirage

# --- Telegram (engine pushes exit-watchdog alerts directly via Bot API) ---
TELEGRAM_BOT_TOKEN=
