# --- LLM provider (DeepSeek, OpenAI-compatible) ---
DEEPSEEK_API_KEY=your_deepseek_api_key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1

# --- On-chain data source (Moralis; free tier covers BSC) ---
# Sign up at https://admin.moralis.com and paste the Web3 Data API key here
MORALIS_API_KEY=your_moralis_api_key
# DUNE_API_KEY=optional_for_sql_ingestion

# --- Datastore (MongoDB for feature cache + verdict history) ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=mirage

# --- Telegram (engine pushes exit-watchdog alerts directly via Bot API) ---
# Same token as apps/bot/.env; lets the engine alert subscribers even if the
# bot process is asleep.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
